#!/usr/bin/env bash
#
# commit-msg hook — keep git history free of AI co-author / "generated by" trailers.
# Standing convention: git history reflects the author's own work.
#
# WHAT THIS DOES (and does NOT do):
#   - It removes KNOWN attribution formats (the standard trailers that tools emit).
#   - It CANNOT catch every possible future wording — a regex that tried to would also
#     delete legitimate text. Novel phrasings are handled by:
#       (1) .claude/settings.json  -> Claude Code does not emit the trailer at all (prevention)
#       (2) CLAUDE.md              -> instructs any AI to add no attribution in any form
#       (3) this hook              -> deterministic catch for known formats
#       (4) your `git log` review before `git push` (push is denied to Claude Code)
#   So this is the backstop, not the whole guarantee.
#
# It only strips lines that look like AI/bot attribution; ordinary text is left alone.
# Installed via: git config core.hooksPath .githooks  (see scripts/install-git-hooks.sh)
#
# Solo project? You can make it stricter by stripping ALL "Co-Authored-By:" lines:
# change the first alternative below to just  '^[[:space:]]*Co-Authored-By:' .

set -euo pipefail

msg_file="$1"
tmp="$(mktemp)"

grep -viE \
  'Co-Authored-By:.*(claude|anthropic|openai|chatgpt|gpt|copilot|cursor|gemini|codex|noreply@)|Assisted-By:.*(claude|ai|gpt|copilot|cursor|gemini)|Generated with[[:space:]]*\[?(claude|ai|gpt|copilot|cursor|gemini)|Co-authored (with|by) .*(claude|ai|gpt|copilot|cursor|gemini)|🤖' \
  "$msg_file" > "$tmp" || true

# Remove any blank lines left dangling at the end of the message.
awk 'NF{last=NR} {line[NR]=$0} END{for(i=1;i<=last;i++) print line[i]}' "$tmp" > "$msg_file"

rm -f "$tmp"
exit 0
